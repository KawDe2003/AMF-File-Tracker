datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String
  role             Role         @default(STAFF)
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id])
  name             String
  nic              String?

  sentFiles        FileMovement[] @relation("Sender")
  receivedFiles    FileMovement[] @relation("Receiver")
  managerApprovals Approval[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  currentFiles     File[]         @relation("CurrentUser")
  
  isCallingAgent   Boolean        @default(false)
}

model Department {
  id               String       @id @default(uuid())
  name             String       @unique
  users            User[]
  filesAtDept      File[]       @relation("CurrentDept")
  movementsFrom    FileMovement[] @relation("FromDept")
  movementsTo      FileMovement[] @relation("ToDept")
}

model File {
  id               String       @id @default(uuid())
  
  // Core identifiers (from screenshot header)
  financeCompany   String?      // Field 1: LB / AMF
  title            String?      // Customer Name (file label)
  leasingCRNo      String?      // Field 2: Deprecated in favor of tagNo/blNo
  tagNo            String?      // New Split Field
  blNo             String?      // New Split Field
  vehicleNo        String?      // Field 3: Bike No (BHE1234)
  engineNo         String?      // New Mandatory Field
  chassisNo        String?      // New Mandatory Field
  regUnreg         String?      // REG / UNREG toggle
  fileReceivedDate String?      // Auto-set date, non-editable

  // Internal tracking (kept from original schema)
  fileType         FileType
  nic              String?      // Field 6: National ID / Passport Number
  priority         Priority     @default(LOW)
  status           FileStatus   @default(AT_BRANCH)
  createdAt        DateTime     @default(now())

  // Branch & Officer
  branchCode           String?  // Field 4
  marketingOfficer     String?  // Field 5

  // Residential Info
  address              String?  // Field 7: Current Residential Address
  residenceType        String?  // Field 8: Owned/Rented/Parental/Company

  // Contact
  contactNo            String?  // Field 9: Contact Number
  whatsappNo           String?  // Field 10
  altContactNo         String?  // Field 11
  bestTimeToCall       String?  // Field 12

  // Employment
  employmentType       String?  // Field 13
  employerName         String?  // Field 14
  jobTitle             String?  // Field 15
  economicSector       String?  // Field 16
  salaryDate           String?  // Field 17
  workExperience       String?  // Field 18
  monthlyIncome        String?  // Field 19
  otherIncome          String?  // Field 20

  // Spouse / Relative Contact
  spouseName           String?  // Field 21
  spouseContact        String?  // Field 22
  spouseRelationship   String?  // Field 23

  // Asset & Financial Details
  bikeMakeModel        String?  // Field 24
  loanAmount           String?  // Field 25
  assetUser            String?  // Field 26
  daysReceivedVehicle  String?  // Field 27
  vehiclePrice         String?  // Field 28
  downPayment          String?  // Field 29
  documentCharges      String?  // Field 30
  insuranceCompany     String?  // Field 31

  // KYC Outcome (Customer)
  guarantorRelationship String? // Field 32 for Customer / Field 21 for Guarantor
  detailsProvided       String? // Field 33
  cooperationRating     Int?    // Field 34: 1-5
  contactType           String? // Field 35: Inbound/Outbound
  specialRemarks        String? // Field 36
  
  // NEW: Detailed Guarantor KYC Data
  guarantorNic              String? 
  guarantorAddress          String?
  guarantorResidenceType    String?
  guarantorContactNo        String?
  guarantorWhatsappNo       String?
  guarantorAltContactNo     String?
  guarantorBestTimeToCall   String?
  guarantorEmploymentType   String?
  guarantorEmployerName     String?
  guarantorJobTitle         String?
  guarantorEconomicSector   String?
  guarantorSalaryDate       String?
  guarantorWorkExperience   String?
  guarantorMonthlyIncome    String?
  guarantorOtherIncome      String?
  guarantorCooperationRating Int?
  guarantorContactType      String?  // Inbound/Outbound
  guarantorSpecialRemarks   String?

  // Verification Data (kept from original)
  customerStatus      VerificationStatus @default(NOT_STARTED)
  customerCallMethod  CallMethod?
  customerComment     String?
  
  guarantorStatus     VerificationStatus @default(NOT_STARTED)
  guarantorCallMethod CallMethod?
  guarantorComment    String?
  
  thirdPartyStatus    ThirdPartyStatus @default(PENDING)
  thirdPartyComment   String?
  
  needsManagerApproval Boolean @default(false)
  
  // Owner/Beneficiary (kept for backward compat)
  ownerName       String?
  beneficiaryName String?
  paymentsDoneBy  String?

  currentDeptId    String?
  currentDept      Department?  @relation("CurrentDept", fields: [currentDeptId], references: [id])
  
  currentUserId    String?
  currentUser      User?        @relation("CurrentUser", fields: [currentUserId], references: [id])
  
  movements        FileMovement[]

  @@index([status])
  @@index([nic])
  @@index([currentDeptId])
  @@index([currentUserId])
  @@index([createdAt])
}

model FileMovement {
  id               String           @id @default(uuid())
  fileId           String
  file             File             @relation(fields: [fileId], references: [id])
  
  senderId         String
  sender           User             @relation("Sender", fields: [senderId], references: [id])
  
  receiverId       String?
  receiver         User?            @relation("Receiver", fields: [receiverId], references: [id])
  
  fromDeptId       String
  fromDept         Department       @relation("FromDept", fields: [fromDeptId], references: [id])
  
  toDeptId         String
  toDept           Department       @relation("ToDept", fields: [toDeptId], references: [id])
  
  status           MovementStatus   @default(PENDING)
  comments         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  approvals        Approval[]

  @@index([fileId])
  @@index([createdAt])
}

model Approval {
  id               String           @id @default(uuid())
  movementId       String
  movement         FileMovement     @relation(fields: [movementId], references: [id])
  
  managerId        String
  manager          User             @relation(fields: [managerId], references: [id])
  
  decision         ApprovalDecision
  comments         String?
  createdAt        DateTime         @default(now())
}

model AuditLog {
  id               String           @id @default(uuid())
  userId           String?
  user             User?            @relation(fields: [userId], references: [id])
  action           String
  details          String?
  timestamp        DateTime         @default(now())
}

model Notification {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  message          String
  readStatus       Boolean          @default(false)
  createdAt        DateTime         @default(now())
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum FileType {
  LEASING
  CR
  LEGAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum FileStatus {
  AT_BRANCH
  IN_TRANSIT
  COMPLETED
}

enum MovementStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum VerificationStatus {
  NOT_STARTED
  CONTACTED
  VERIFIED
  NOT_VERIFIED
  UNABLE_TO_CONTACT
}

enum CallMethod {
  PHONE
  SMS
  WHATSAPP
  VISIT
  OTHER
}

enum ThirdPartyStatus {
  PENDING
  VERIFIED
  NOT_VERIFIED
}

model AllocationConfig {
  id              String   @id @default("1")
  filesPerAgent   Int      @default(10)
  autoAllocate    Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}
